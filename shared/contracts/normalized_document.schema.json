{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scientific-tangle.local/contracts/normalized_document.schema.json",
  "title": "NormalizedDocument",
  "type": "object",
  "required": [
    "document_id",
    "task_id",
    "title",
    "source_type",
    "source_path",
    "language",
    "access_level",
    "blocks",
    "tables",
    "source_spans",
    "parse_warnings"
  ],
  "properties": {
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "folder_category": {
      "type": [
        "string",
        "null"
      ]
    },
    "language": {
      "type": "string",
      "minLength": 2
    },
    "metadata": {
      "type": "object"
    },
    "access_level": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ]
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "block_id",
          "text"
        ],
        "properties": {
          "block_id": {
            "type": "string"
          },
          "page": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "text": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "tables": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "source_spans": {
      "type": "array",
      "items": {
        "$ref": "source_span.schema.json"
      }
    },
    "parse_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
