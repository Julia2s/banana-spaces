{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scientific-tangle.local/contracts/retrieval_document.schema.json",
  "title": "RetrievalDocumentPayload",
  "type": "object",
  "required": [
    "retrieval_document_id",
    "text",
    "document_id",
    "title",
    "source_type",
    "source_path",
    "access_level",
    "metadata"
  ],
  "properties": {
    "retrieval_document_id": {
      "type": "string",
      "minLength": 1
    },
    "text": {
      "type": "string",
      "minLength": 1
    },
    "source_span_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "access_level": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ]
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
