{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scientific-tangle.local/contracts/document_artifact.schema.json",
  "title": "DocumentArtifactPayload",
  "type": "object",
  "required": [
    "document_id",
    "task_id",
    "title",
    "source_type",
    "artifact_path",
    "source_span_count",
    "parse_warnings"
  ],
  "properties": {
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "artifact_path": {
      "type": "string",
      "minLength": 1
    },
    "source_span_count": {
      "type": "integer",
      "minimum": 0
    },
    "parse_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
