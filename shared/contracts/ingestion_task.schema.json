{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scientific-tangle.local/contracts/ingestion_task.schema.json",
  "title": "IngestionTaskPayload",
  "type": "object",
  "required": [
    "task_id",
    "status",
    "access_level",
    "files",
    "created_at",
    "updated_at",
    "started_at",
    "completed_at",
    "error_message",
    "warnings"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "uploaded",
        "queued",
        "parsing",
        "normalized",
        "completed",
        "failed"
      ]
    },
    "access_level": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ]
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "filename",
          "size_bytes",
          "storage_path"
        ],
        "properties": {
          "filename": {
            "type": "string",
            "minLength": 1
          },
          "content_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "storage_path": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "started_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "error_message": {
      "type": [
        "string",
        "null"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
