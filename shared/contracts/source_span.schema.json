{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scientific-tangle.local/contracts/source_span.schema.json",
  "title": "SourceSpan",
  "type": "object",
  "required": [
    "source_span_id",
    "document_id",
    "raw_text",
    "access_level"
  ],
  "properties": {
    "source_span_id": {
      "type": "string",
      "minLength": 1
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "page": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "table_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "row_index": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "column_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "char_start": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "char_end": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "raw_text": {
      "type": "string",
      "minLength": 1
    },
    "parsed_text": {
      "type": [
        "string",
        "null"
      ]
    },
    "access_level": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ]
    }
  },
  "additionalProperties": false
}
