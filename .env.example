GATEWAY_ENVIRONMENT=local
GATEWAY_RAW_UPLOAD_DIR=data/raw_uploads
GATEWAY_NORMALIZED_DIR=data/normalized
GATEWAY_SOURCE_CORPUS_DIR=demo/seed_data
GATEWAY_DB_DSN=postgresql://scientific_tangle:scientific_tangle@localhost:5432/scientific_tangle
GATEWAY_RETRIEVAL_SOURCE_CHAR_LIMIT=8000
GATEWAY_RETRIEVAL_TOP_K_DEFAULT=10

# Neo4j
GATEWAY_NEO4J_URI=bolt://localhost:7687
GATEWAY_NEO4J_USER=neo4j
GATEWAY_NEO4J_PASSWORD=scientific_tangle

# Qdrant
GATEWAY_QDRANT_URL=http://localhost:6333
GATEWAY_QDRANT_COLLECTION=st_chunks
GATEWAY_QDRANT_VECTOR_DIM=768

# YandexGPT — НЕ КОММИТИТЬ реальные значения!
# Получить folder_id: https://console.yandex.cloud/cloud
# Получить IAM token: yc iam create-token (через YC CLI) или OAuth
GATEWAY_YANDEX_FOLDER_ID=
GATEWAY_YANDEX_IAM_TOKEN=
GATEWAY_YANDEXGPT_MODEL=yandexgpt-4-pro
GATEWAY_YANDEX_EMBEDDINGS_MODEL=emb:text-search-doc
GATEWAY_YANDEX_API_URL=https://llm.api.cloud.yandex.net/llm/v1

# Embeddings backend: "sentence-transformers" (по умолчанию, локально) или "yandex"
GATEWAY_EMBEDDINGS_BACKEND=sentence-transformers
GATEWAY_EMBEDDINGS_MODEL_NAME=sentence-transformers/LaBSE

# Audit
GATEWAY_AUDIT_ENABLED=true
GATEWAY_AUDIT_LOG_BODY=false

# PostgreSQL
POSTGRES_DB=scientific_tangle
POSTGRES_USER=scientific_tangle
POSTGRES_PASSWORD=scientific_tangle

# Neo4j
NEO4J_AUTH=neo4j/scientific_tangle
HEALTHCHECK_NEO4J_USER=neo4j
HEALTHCHECK_NEO4J_PASSWORD=scientific_tangle

# MinIO
MINIO_ROOT_USER=scientific_tangle
MINIO_ROOT_PASSWORD=scientific_tangle_minio
